# linklore — environment template.
# Copy to ".env" and fill in. .env is git-ignored. Process env wins
# over .env, so a one-shot `OPENAI_API_KEY=… ./linklore serve` still
# overrides the file.

# ---- LLM backend ----
# Pick one:
#   none    — run without an LLM (search degrades to BM25-only).
#   openai  — any OpenAI-compatible HTTP API. The canonical choice
#             for ALL local servers: vLLM, llama.cpp, LM Studio,
#             LiteLLM proxy, and Ollama via its /v1 endpoint.
#   ollama  — Ollama's *native* /api/* endpoints (legacy). Only
#             pick this if you specifically need native options;
#             otherwise use openai with base_url=http://localhost:11434/v1.
# LINKLORE_LLM_BACKEND=openai

# ---- OpenAI-compatible gateway (backend=openai) ----
# Examples:
#   Ollama via OpenAI API : http://localhost:11434/v1
#   llama.cpp server      : http://localhost:8080/v1
#   vLLM                  : http://localhost:8000/v1
#   LiteLLM proxy         : http://localhost:4000/v1
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# LINKLORE_LLM_MODEL=qwen3:14b
# LINKLORE_LLM_EMBED_MODEL=nomic-embed-text

# ---- Ollama native (backend=ollama) ----
# OLLAMA_HOST=http://localhost:11434

# ---- Legacy aliases (still accepted, prefer the names above) ----
# LITELLM_BASE_URL=  → OPENAI_BASE_URL
# LITELLM_API_KEY=   → OPENAI_API_KEY
# LINKLORE_LLM_BACKEND=litellm  → openai

# ---- Server ----
# LINKLORE_ADDR=127.0.0.1:8080
# LINKLORE_DB_PATH=./data/linklore.db
# LINKLORE_WORKER_CONCURRENCY=4
