# linklore — environment template.
# Copy to ".env" and fill in. .env is git-ignored. Process env wins
# over .env, so a one-shot `LITELLM_API_KEY=… ./linklore serve` still
# overrides the file.

# ---- LLM backend ----
# Pick one:
#   none     — run without an LLM (search degrades to BM25-only).
#   ollama   — local Ollama daemon (default http://localhost:11434).
#   litellm  — any OpenAI-compatible gateway (LiteLLM, llama.cpp server, vLLM, …).
# LINKLORE_LLM_BACKEND=ollama

# ---- LiteLLM gateway ----
# LITELLM_BASE_URL=http://localhost:4000/v1
# LITELLM_API_KEY=
# LINKLORE_LLM_MODEL=qwen3:14b
# LINKLORE_LLM_EMBED_MODEL=nomic-embed-text

# ---- Ollama ----
# OLLAMA_HOST=http://localhost:11434

# ---- Server ----
# LINKLORE_ADDR=127.0.0.1:8080
# LINKLORE_DB_PATH=./data/linklore.db
# LINKLORE_WORKER_CONCURRENCY=4
