# linklore — environment template.
# Copy to ".env" and fill in. .env is git-ignored. Process env wins
# over .env, so a one-shot `OPENAI_API_KEY=… ./linklore serve` still
# overrides the file.

# ---- LLM backend ----
#   none    — run without an LLM (search degrades to BM25-only).
#   openai  — any OpenAI-compatible HTTP API (recommended for ALL
#             local servers: vLLM, llama.cpp, LM Studio, …).
# LINKLORE_LLM_BACKEND=openai

# ---- Local LLM (no key needed) ----
# OPENAI_API_KEY is OPTIONAL. Leave it unset / empty for local
# servers that don't auth — linklore won't send an Authorization
# header at all. Some picky local servers want *any* non-empty
# bearer; in that case put a placeholder like "local".
# OPENAI_BASE_URL=http://localhost:8000/v1
# LINKLORE_LLM_MODEL=qwen3:14b
# LINKLORE_LLM_EMBED_MODEL=nomic-embed-text
# OPENAI_API_KEY=                   # leave empty for local

# ---- Real OpenAI cloud ----
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...your-real-key...
# LINKLORE_LLM_MODEL=gpt-4o-mini
# LINKLORE_LLM_EMBED_MODEL=text-embedding-3-small

# ---- Ollama via OpenAI API (recommended for Ollama users) ----
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=                   # Ollama ignores it; leave empty
# LINKLORE_LLM_MODEL=qwen3:14b
# LINKLORE_LLM_EMBED_MODEL=nomic-embed-text

# ---- Ollama native API (legacy — only if /v1 doesn't expose a flag you need) ----
# LINKLORE_LLM_BACKEND=ollama
# OLLAMA_HOST=http://localhost:11434

# ---- Server ----
# LINKLORE_ADDR=127.0.0.1:8080
# LINKLORE_DB_PATH=./data/linklore.db
# LINKLORE_WORKER_CONCURRENCY=4
